# ────────────────────────────────────────────────────────────────────────────
#  Blogify Backend — Environment Variables
#
#  Copy this file to .env and fill in the values for your environment.
#  NEVER commit .env (it contains secrets) — only .env.example is safe to
#  commit.
# ────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/bloghub_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ── Clerk JWT Verification ───────────────────────────────────────────────────
# Find your Frontend API URL in the Clerk dashboard → API Keys page.
# It looks like https://prepared-condor-42.clerk.accounts.dev
# The full JWKS URI is <Frontend API URL>/.well-known/jwks.json
CLERK_JWKS_URI=https://YOUR-CLERK-FRONTEND-API/.well-known/jwks.json

# ── AWS S3 (for avatar, cover, and blog-block image uploads) ─────────────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Optional — only needed for LocalStack or other S3-compatible stores:
# AWS_S3_ENDPOINT=http://localhost:4566
# AWS_S3_PATH_STYLE=true

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins:
CORS_ALLOWED_ORIGINS=http://localhost:3000
