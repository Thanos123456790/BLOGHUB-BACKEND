# Copy this file to .env (or export these in your shell / CI / container
# orchestrator) before running the app. NEVER commit a real .env file.

# ─── Database ────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/bloghub_db
DB_USERNAME=postgres
DB_PASSWORD=change-me

# ─── AWS S3 ──────────────────────────────────────────────────────────────
# Picked up automatically by the AWS SDK default credential provider chain.
# Prefer an IAM role / instance profile in deployed environments instead of
# static keys. Only use static keys for local development.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=aws-s3-bloghub-bucket
# Leave AWS_S3_ENDPOINT empty to use real AWS S3. Set it to
# http://localhost:4566 (and AWS_S3_PATH_STYLE=true) when using LocalStack.
AWS_S3_ENDPOINT=
AWS_S3_PATH_STYLE=false

# ─── CORS ────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
